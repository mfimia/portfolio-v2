---
const projects = [
  {
    title: "SOLRentClaimer",
    description: "Crypto tool on the Solana blockchain used by thousands of users. Processing real transactions and generating daily revenue in the DeFi space.",
    tags: ["Solana Web3", "Next.js", "Tailwind CSS"],
    link: "https://solrentclaimer.com",
    github: null,
    status: "live",
  },
  {
    title: "AutoRegistro",
    description: "SaaS platform helping Spanish hosts manage their rental property guest registrations. Serving paying customers and simplifying compliance with local regulations.",
    tags: ["Next.js", "PostgreSQL", "Tailwind CSS"],
    link: "https://autoregistro.es",
    github: null,
    status: "live",
  },
  {
    title: "VivaSpeak",
    description: "Voice AI company building intelligent voice agents. Collaborating on the tech that powers real conversations at scale, generating real revenue.",
    tags: ["Voice AI", "Conversational Agents"],
    link: null,
    github: null,
    status: "live",
  },
  {
    title: "Lead Generation System",
    description: "Building a system to help startups distribute their solution to the right audience. Connecting products with the people who need them.",
    tags: ["Lead Gen", "Startups", "Distribution"],
    link: null,
    github: null,
    status: "coming soon",
  },
];
---

<section id="projects" class="relative py-24 md:py-32 circuit-bg">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="mb-4 font-heading text-4xl font-bold uppercase tracking-wide text-fg md:text-5xl">
      <span class="text-accent">//</span> Products
    </h2>
    <p class="mb-16 font-label text-sm uppercase tracking-[0.2em] text-fg-muted">
      &gt; ls -la ~/products
    </p>

    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <div class="group cyber-chamfer border border-border bg-bg-card transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:neon-glow">
          <!-- Status bar -->
          <div class="flex items-center justify-between border-b border-border px-6 py-3">
            <span class="font-label text-xs uppercase tracking-widest text-fg-muted">{project.title}</span>
            <span class={`font-label text-xs uppercase tracking-widest ${project.status === "live" ? "text-accent" : "text-accent-secondary"}`}>
              {project.status === "live" ? "● LIVE" : "◌ COMING SOON"}
            </span>
          </div>

          <div class="p-6">
            <div class="mb-2 flex items-center justify-between">
              <h3 class="font-heading text-xl font-bold uppercase tracking-wide text-fg group-hover:text-accent">
                {project.title}
              </h3>
              <div class="flex gap-3">
                {project.github && (
                  <a href={project.github} class="text-fg-muted transition-colors hover:text-accent" aria-label={`${project.title} source code`}>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  </a>
                )}
                {project.link && (
                  <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-fg-muted transition-colors hover:text-accent-tertiary" aria-label={`${project.title} live site`}>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                  </a>
                )}
              </div>
            </div>

            <p class="mb-4 text-sm leading-relaxed tracking-wide text-fg-muted">{project.description}</p>

            <ul class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <li class="cyber-chamfer-sm bg-bg-muted px-3 py-1 font-label text-xs uppercase tracking-widest text-accent">
                  {tag}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
