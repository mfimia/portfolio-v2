---
const links = [
  { label: "About", href: "#about" },
  { label: "Projects", href: "#projects" },
  { label: "Approach", href: "#approach" },
  { label: "Contact", href: "#contact" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-6 md:py-4">
    <a href="/" class="font-heading text-base font-bold tracking-widest uppercase text-accent neon-text md:text-lg">
      &lt;MF /&gt;
    </a>

    <!-- Desktop links -->
    <ul class="hidden gap-8 md:flex">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-label text-sm uppercase tracking-[0.2em] text-fg-muted transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="#contact"
      class="hidden cyber-chamfer-sm border-2 border-accent bg-transparent px-5 py-2 font-label text-sm uppercase tracking-widest text-accent transition-all hover:bg-accent hover:text-bg md:inline-block"
    >
      Get in touch
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center text-fg-muted md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-bg/95 backdrop-blur-md md:hidden">
    <ul class="flex flex-col px-4 py-4">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block py-3 font-label text-sm uppercase tracking-[0.2em] text-fg-muted transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2 border-t border-border pt-4">
        <a
          href="#contact"
          class="mobile-link block py-2 font-label text-sm uppercase tracking-widest text-accent"
        >
          Get in touch →
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const mobileLinks = menu?.querySelectorAll(".mobile-link");

  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
