---
---

<section class="relative flex min-h-screen items-center circuit-bg pt-20">
  <!-- Gradient mesh accents -->
  <div class="pointer-events-none absolute left-0 top-0 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/5 blur-[120px]"></div>
  <div class="pointer-events-none absolute bottom-0 right-0 h-[400px] w-[400px] translate-x-1/3 translate-y-1/3 rounded-full bg-accent-secondary/5 blur-[100px]"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-4xl">
      <!-- Terminal prefix -->
      <p class="mb-4 font-label text-sm uppercase tracking-[0.2em] text-accent">
        <span class="text-fg-muted">&gt;</span> system.init<span class="cursor-blink"></span>
      </p>

      <!-- Headline -->
      <h1
        class="cyber-glitch mb-6 font-heading text-5xl font-black uppercase leading-tight tracking-widest md:text-7xl lg:text-8xl"
        data-text="MARTÍN FIMIA"
      >
        <span class="text-fg">MARTÍN</span><br />
        <span class="text-accent neon-text">FIMIA</span>
      </h1>

      <!-- Subtitle -->
      <p class="mb-8 max-w-2xl font-body text-lg leading-relaxed tracking-wide text-fg-muted md:text-xl">
        <span class="text-accent-tertiary">[</span>
        Software Engineer &amp; Tech Entrepreneur
        <span class="text-accent-tertiary">]</span>
        — I build products that people actually use. From crypto tools processing real transactions to SaaS platforms serving paying customers daily, I turn ideas into revenue-generating software.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-4">
        <a
          href="#projects"
          class="cyber-chamfer-sm bg-accent px-8 py-3 font-label text-sm font-bold uppercase tracking-widest text-bg transition-all hover:brightness-110"
        >
          View Projects
        </a>
        <a
          href="#contact"
          class="cyber-chamfer-sm border-2 border-accent-secondary bg-transparent px-8 py-3 font-label text-sm uppercase tracking-widest text-accent-secondary transition-all hover:bg-accent-secondary hover:text-bg"
        >
          Let's Talk
        </a>
      </div>

      <!-- Stats HUD -->
      <div class="mt-16 hidden items-center divide-x divide-border font-label text-sm uppercase tracking-[0.2em] lg:flex">
        <div class="pr-8">
          <span class="text-2xl font-bold text-accent">6+</span>
          <span class="ml-2 text-fg-muted">Years Building</span>
        </div>
        <div class="px-8">
          <span class="text-2xl font-bold text-accent-tertiary">1000+</span>
          <span class="ml-2 text-fg-muted">Users Served</span>
        </div>
        <div class="px-8">
          <span class="text-2xl font-bold text-accent-secondary">20+</span>
          <span class="ml-2 text-fg-muted">Products Shipped</span>
        </div>
      </div>
    </div>
  </div>
</section>
